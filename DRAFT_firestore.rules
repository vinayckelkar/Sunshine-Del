rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && incoming().role == 'Staff'; // Default to staff on first sign-in
      allow update: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Staff can update status
      allow delete: if isAdmin();
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
